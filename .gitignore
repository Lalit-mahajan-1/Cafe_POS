# ───────────────────────────────────────────────
/.next/
/out/
/build
next-env.d.ts

# ───────────────────────────────────────────────
# Production
# ───────────────────────────────────────────────
/dist

# ───────────────────────────────────────────────
# Environment Variables (NEVER commit these!)
# ───────────────────────────────────────────────
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
.env*.local
!.env.example
!.env.sample

# ───────────────────────────────────────────────
# Prisma
# ───────────────────────────────────────────────
# Keep migrations folder! Only ignore generated client
# prisma/migrations/  ← DO NOT IGNORE THIS
/prisma/generated
*.db
*.db-journal

# ───────────────────────────────────────────────
# Logs & Debug
# ───────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
lerna-debug.log*
*.log
logs/

# ───────────────────────────────────────────────
# Testing
# ───────────────────────────────────────────────
/coverage
/.nyc_output
*.lcov
/test-results
/playwright-report
/playwright/.cache

# ───────────────────────────────────────────────
# Editor / IDE
# ───────────────────────────────────────────────
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json
.idea/
*.swp
*.swo
*.sublime-workspace
*.sublime-project

# ───────────────────────────────────────────────
